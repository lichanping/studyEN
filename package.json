{
  "name": "studyen",
  "private": true,
  "scripts": {
    "dev:local": "npx --yes netlify-cli@latest dev --port 8888",
    "dev:localhost": "bash ./scripts/dev_localhost.sh",
    "dev:localhost:check": "bash ./scripts/dev_localhost.sh --check",
    "build:reading-manifest": "node scripts/generate_reading_articles_manifest.js",
    "test:reading-articles": "node tests/test-reading-article-library.js",
    "test:reading-articles-regression": "node tests/test-reading-articles-page-regression.js",
    "test:reading-article-share-token": "node tests/test-reading-article-share-token.js",
    "test:reading-article-share-functions": "node tests/test-reading-article-share-functions.js",
    "test:meeting-config": "node tests/test-meeting-config.js",
    "test:quota": "node tests/test-quota-check.js",
    "test:schedule-match": "node tests/test-schedule-course-match.js",
    "test:all": "npm run test:meeting-config && npm run test:quota && npm run test:schedule-match && node tests/test-student-name-alias.js",
    "rollback:sync": "bash ./scripts/rollback_sync.sh --target HEAD~1 --yes",
    "rollback:sync:dry": "bash ./scripts/rollback_sync.sh --target HEAD~1 --dry-run"
  },
  "dependencies": {
    "@andresaya/edge-tts": "^1.8.0",
    "@netlify/blobs": "^8.1.0"
  }
}
